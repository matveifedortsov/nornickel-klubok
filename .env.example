# Скопируйте в .env и заполните под своё окружение.

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=klubok_dev_password

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=klubok_chunks

# --- Эмбеддинги ---
# mock   -> детерминированный заглушечный эмбеддер (без сети, для разработки)
# bge    -> BAAI/bge-m3 (нужно железо)
# yandex -> Yandex AI Studio textEmbedding (dim=256, боевой бэкенд)
EMBEDDER_BACKEND=mock
EMBEDDER_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# --- LLM ---
# mock     -> детерминированные триплеты/ответы (без сети)
# metalgpt -> MetalGPT-1 через vLLM (on-prem, нужен GPU)
# yandex   -> YandexGPT через Yandex AI Studio (боевой бэкенд хакатона)
LLM_BACKEND=mock
METALGPT_MODEL=Nornickel/MetalGPT-1
METALGPT_BASE_URL=http://localhost:8000/v1
METALGPT_API_KEY=EMPTY

# --- Yandex AI Studio ---
# Для боевого прогона: LLM_BACKEND=yandex, EMBEDDER_BACKEND=yandex.
# ⚠️ Реальные значения только здесь (в .env), НЕ в .env.example и НЕ в git.
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_LLM_MODEL=yandexgpt/latest
# yandexgpt-lite/latest — дешевле/быстрее для массового извлечения
YANDEX_RPS=5
YANDEX_MAX_RETRIES=5
YANDEX_EMBEDDING_DIM=256

# --- Прочее ---
DATA_DIR=./data
LOG_LEVEL=INFO
